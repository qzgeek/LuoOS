{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "sources": "${mod_sources}",
    "issues": "${mod_issues}"
  },
  "license": "${mod_license}",
  "environment": "server",
  "entrypoints": {
    "main": [
      "heos.HeosFabric"
    ]
  },
  "accessWidener": "accesswidener/heos.1.21.2.accesswidener",
  "mixins": [
    "heos.mixins.json",
    "heos.bugfix.ghost_pearl.mixins.json"
  ],
  "depends": {
    "fabric-api": "*",
    "fabricloader": ">=0.15.0",
    "minecraft": "${supported_minecraft_version}"
  }
}
